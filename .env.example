# ═══════════════════════════════════════════════════
# LeadMaster — Environment Variables
# ═══════════════════════════════════════════════════
# 1. Rename this file to .env.local
# 2. Fill in your Supabase values
# 3. Push to GitHub → Vercel will ask for these on deploy

# ── Supabase ────────────────────────────────────────
# Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ⚠️  SERVICE ROLE KEY — SERVER-SIDE ONLY, NEVER EXPOSED TO BROWSER
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── App ─────────────────────────────────────────────
# Development: http://localhost:3000
# Production:  https://your-app.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000
